{
  "name": "kubevirt",
  "version": "0.1.0",
  "description": "A comprehensive Headlamp plugin for managing KubeVirt virtual machines in Kubernetes",
  "author": "Alexandre Knecht",
  "homepage": "https://github.com/naval-group/headlamp-kubevirt",
  "license": "Apache-2.0",
  "headlamp": {
    "minVersion": "0.24.0",
    "maxVersion": "0.99.0"
  },
  "scripts": {
    "start": "headlamp-plugin start",
    "build": "headlamp-plugin build",
    "format": "headlamp-plugin format",
    "lint": "headlamp-plugin lint",
    "lint-fix": "headlamp-plugin lint --fix",
    "package": "headlamp-plugin package",
    "tsc": "headlamp-plugin tsc",
    "storybook": "headlamp-plugin storybook",
    "storybook-build": "headlamp-plugin storybook-build",
    "test": "headlamp-plugin test"
  },
  "keywords": [
    "headlamp",
    "headlamp-plugin",
    "kubernetes",
    "kubevirt",
    "virtualization",
    "virtual-machine",
    "vmi",
    "vnc"
  ],
  "prettier": "@headlamp-k8s/eslint-config/prettier-config",
  "eslintConfig": {
    "extends": [
      "@headlamp-k8s",
      "prettier",
      "plugin:jsx-a11y/recommended"
    ]
  },
  "overrides": {
    "typescript": "5.6.2"
  },
  "devDependencies": {
    "@kinvolk/headlamp-plugin": "^0.13.1",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.6",
    "@types/js-yaml": "^4.0.9",
    "fast-check": "^4.6.0",
    "msw": "^2.12.14",
    "msw-storybook-addon": "^2.0.6",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "js-yaml": "^4.1.0",
    "recharts": "^3.8.0"
  },
  "msw": {
    "workerDirectory": [
      ".storybook/public"
    ]
  }
}
